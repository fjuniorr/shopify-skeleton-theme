{% if section.settings.text != blank %}
  <div class="announcement-bar full-width" style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
    <div class="announcement-bar__content">
      {% if section.settings.link != blank %}
        <a href="{{ section.settings.link }}" style="color: {{ section.settings.text_color }};">
          {{ section.settings.text }}
        </a>
      {% else %}
        <p>{{ section.settings.text }}</p>
      {% endif %}
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .announcement-bar {
    display: grid;
    grid-template-columns: var(--content-grid);
    text-align: center;
    padding: 10px 0;
    font-size: 0.875rem;
  }

  .announcement-bar__content {
    grid-column: 2;
  }

  .announcement-bar a {
    text-decoration: none;
  }

  .announcement-bar a:hover {
    text-decoration: underline;
  }

  .announcement-bar p {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.announcement_bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "t:labels.text",
      "default": "Welcome to our store"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:labels.link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background_color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.text_color",
      "default": "#FFFFFF"
    }
  ]
}
{% endschema %}
